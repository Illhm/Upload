time\\\\\\\\\\\\\\\":1782435491,\\\\\\\\\\\\\\\"address_detail\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"Jalan Ds Sidowayah, RT.1/RW.1, Desa Sidowayah\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"address_province\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"JAWA TENGAH\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"address_city\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"KAB. REMBANG\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"address_district\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"PANCUR\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"latitude\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"-6.736013111171682\\\\\\\\\\\\\\\",\\\\\\\\\\\\\\\"longitude\\\\\\\\\\\\\\\":\\\\\\\\\\\\\\\"111.50293355807662\\\\\\\\\\\\\\\"}}\\\\\\\"}]|cbb604c03c268a90783c2984253702ead5a0aaf699107c77645e2fbfa82cec79\\\",\\\"channel_status_report_data\\\":2,\\\"always_expanded\\\":true}\",\"enabled\":false,\"always_expanded\":true,\"info_link\":\"https://shopee.co.id/m/tentang-spaylater\",\"version\":2,\"payment_disclaimer\":{\"enabled\":true,\"preview\":\"Dengan melanjutkan, saya telah membaca dan menyetujui {{Perjanjian Pembiayaan}}.\",\"header\":\"Perjanjian Pembiayaan\",\"body\":\"Dengan melanjutkan, saya telah membaca dan menyetujui {{Perjanjian Pembiayaan}}.\",\"url\":\"https://spl-h5.cmf.co.id/contract/preview\",\"items\":[{\"urls\":[],\"buttonType\":0,\"type\":1,\"body\":\"Setiap transaksi akan tercatat pada sistem layanan informasi keuangan (SLIK) Otoritas Jasa Keuangan, yaitu sistem yang mencatat riwayat pinjaman debitur atas utang kepada lembaga keuangan. Transaksi ini berpotensi menimbulkan terjadinya penumpukan hutang dan dalam hal pinjaman dinyatakan bermasalah dapat mengakibatkan terblokirnya akses pada layanan keuangan lainnya. Berhati-hati, selalu bijak dalam bertransaksi, sesuaikan dengan kebutuhan dan kemampuan membaya. Jika Anda melakukan pembayaran dengan Cicilan 0%, pastikan Anda memahami Syarat dan Ketentuan Program Biaya Cicilan 0% SPayLater: Program ini hanya berlaku jika semua cicilan pinjaman SPayLater yang bersangkutan dibayar tepat waktu. Jika Anda terlambat membayar cicilan, Program Biaya Cicilan 0% akan berakhir secara otomatis. Mulai dari tanggal keterlambatan pembayaran, cicilan yang jatuh tempo dan semua cicilan selanjutnya dari pinjaman SPayLater yang bersangkutan akan dikenakan tarif biaya cicilan yang ditentukan oleh PT Commerce Finance. Biaya keterlambatan pembayaran atau biaya lainnya juga dapat berlaku sebagaimana tercantum dalam Perjanjian Pembiayaan SPayLater.\",\"header\":\"Himbauan Transaksi & Promosi\",\"preview\":\"Himbauan Transaksi & Promosi\"},{\"urls\":[\"https://spl-h5.cmf.co.id/contract/preview\"],\"buttonType\":0,\"type\":2,\"body\":\"Dengan melanjutkan, saya telah membaca dan menyetujui {{RIPLAY dan Perjanjian Pembiayaan SPayLater}}.\",\"header\":\"RIPLAY & Perjanjian Pembiayaan SPayLater\",\"preview\":\"RIPLAY dan Perjanjian Pembiayaan SPayLater\"}]},\"banner_campaign\":{\"redirect_link\":\"\",\"start_time\":0,\"end_time\":0,\"need_double_check\":false,\"content\":\"\",\"color\":\"\"},\"be_channel_id\":85001,\"payment_channel_banners\":[],\"preselect_disabled_reason\":\"\",\"description\":\"Bebas biaya admin. Dapatkan cicilan 0% untuk tenor tertentu!\",\"partner_account_info\":{\"force_grey_out\":false,\"additional_info\":10,\"tracking_info\":\"{\\\"activation_status\\\":\\\"activate_now\\\"}\",\"rules_same_flag\":false,\"is_new_account\":true,\"display_text\":\"Aktifkan\",\"display_color\":\"#ee4d2d\",\"partners_link\":\"https://uc-h5.cmf.co.id/landing/spl?channel=paymentselectionpage\",\"rules_sku_names\":[],\"balance\":0,\"should_show_button\":true,\"user_status\":1},\"display_message\":\"\",\"hint\":\"\",\"category\":24,\"wallet_balance\":0,\"always_show\":false,\"preselect_disabled\":false,\"spm_channel_id\":8002601,\"ccb_text\":\"\",\"name_label\":\"label_shopee_credit\",\"extra_data\":{\"include_shipping_and_discounts\":false,\"expiry_duration\":3600,\"price_limit\":0,\"banned_categories\":[],\"sub_description_1\":\"\",\"v1_channel_grouping_info\":{\"icon_background\":\"\",\"group_id\":0,\"version\":0,