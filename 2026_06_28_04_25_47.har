ang bersangkutan akan dikenakan tarif biaya cicilan yang ditentukan oleh PT Commerce Finance. Biaya keterlambatan pembayaran atau biaya lainnya juga dapat berlaku sebagaimana tercantum dalam Perjanjian Pembiayaan SPayLater.\",\"header\":\"Himbauan Transaksi & Promosi\"},{\"urls\":[\"https://spl-h5.cmf.co.id/contract/preview\"],\"buttonType\":0,\"type\":2,\"body\":\"Dengan melanjutkan, saya telah membaca dan menyetujui {{RIPLAY dan Perjanjian Pembiayaan SPayLater}}.\",\"header\":\"RIPLAY & Perjanjian Pembiayaan SPayLater\",\"preview\":\"RIPLAY dan Perjanjian Pembiayaan SPayLater\"}],\"enabled\":true,\"preview\":\"Dengan melanjutkan, saya telah membaca dan menyetujui {{Perjanjian Pembiayaan}}.\",\"header\":\"Perjanjian Pembiayaan\",\"body\":\"Dengan melanjutkan, saya telah membaca dan menyetujui {{Perjanjian Pembiayaan}}.\"},\"channel_blackbox\":\"{\\\"spl_channel\\\":{\\\"monthly_payments\\\":[{\\\"amount\\\":101000000,\\\"be_channel_id\\\":85002}]},\\\"spm_txn_extra_data\\\":\\\"\\\"}\",\"installment_promotion_text\":\"\",\"payment_result_text\":\"\",\"groups\":{\"credit_card\":false,\"maribank\":false,\"bank_account\":false,\"cod\":false,\"seabank\":false,\"spl\":true,\"immediate\":false,\"wallet\":false,\"installment\":true,\"spm_channel\":true,\"airpay\":false,\"general_card\":false,\"bank_transfer\":false},\"icon_background\":\"\",\"installment_plans\":[{\"tenure\":1,\"handling_fee\":0,\"total_amount\":0,\"promotions\":[{\"display_type\":\"label\",\"card_promotion_id_v2\":\"463069784600773\",\"bank_logo\":\"\",\"end_time\":0,\"error_code\":0,\"description\":\"\",\"primary_color\":\"\",\"is_fully_redeemed\":false,\"start_time\":0,\"banner_title_text\":\"\",\"url\":\"\",\"discount_type\":2,\"max_discount_value\":\"\",\"coin_earn_rate\":0,\"title\":\"\",\"discount_value\":\"99\",\"card_promotion_id\":463069784600773,\"is_available\":true}],\"bank_id\":0,\"recommend_label_text\":\"Rekomendasi\",\"plan_name\":\"Beli Sekarang, Bayar Nanti\",\"monthly_payment\":1010000